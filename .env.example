# Copy to .env and fill in. Never commit .env.

# Dify — App API key (Dify → your app → API Access)
DIFY_API_KEY=

# API origin only (no /v1). Examples:
#   Cloud:  https://api.dify.ai
#   Self:   http://localhost:5001   (or your Docker / reverse-proxy URL)
# Wrong:   http://localhost:3000   (that is this Next app, not Dify)
DIFY_API_BASE=https://api.dify.ai
